# =============================================================================
# Neural Network Theory Deep Dive — .gitignore
# =============================================================================

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / Packaging
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Jupyter Notebook ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── NumPy / SciPy / PyTorch cache ────────────────────────────────────────────
*.npy
*.npz
*.pkl
*.pickle
*.joblib
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# torch / tensorboard cache
.torch_cache/
.cache/
tensorboard_logs/

# ── Dataset / Model weights ──────────────────────────────────────────────────
# MNIST / CIFAR / ImageNet 등 데이터셋 (CNN·RNN 실험용)
data/
datasets/
MNIST/
cifar-10-batches-py/
cifar-100-python/
*.tar.gz
*.zip
*.gz

# 사전학습 모델 weights (크기가 크므로 제외)
pretrained/
weights/
models/
*.bin

# ── Experiment outputs ───────────────────────────────────────────────────────
# 생성된 이미지 파일 (각 챕터의 시각화 결과물 — 분산 전파 plot, gradient flow 등)
*.png
*.jpg
*.jpeg
*.svg
*.pdf
*.gif
*.mp4

# NN 학습 결과 / 체크포인트 / 로그
results/
outputs/
logs/
checkpoints/
samples/
runs/
wandb/
mlruns/
tb_logs/
*.log
*.csv
*.h5
*.hdf5
*.tfevents.*

# ── IDE / Editor ─────────────────────────────────────────────────────────────
# JetBrains (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# VSCode
.vscode/
*.code-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# ── Documentation build ──────────────────────────────────────────────────────
docs/_build/
docs/generated/
site/
.mkdocs_cache/

# ── Secrets / Credentials ────────────────────────────────────────────────────
.env.local
.env.*.local
secrets.py
credentials.json
*.pem
*.key

# ── Testing / Linting ────────────────────────────────────────────────────────
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
*.mo
*.pot

# ── Miscellaneous ────────────────────────────────────────────────────────────
